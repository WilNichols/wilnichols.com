{% from "../_includes/picture.njk" import Picture with context %}
{% from "../_includes/footer.njk" import Footer with context %}

{% set currentGroup = "" %}
{% set prevAlbumOpen = false %}
<ol class="album-groups-list" reversed>
  {% asyncEach album in collections.Albums | sortByAlbumGroup %}
    {% if album.data.permalink and (album.data.thumbnail !== '') %}
      {% set albumGroup %}{% for tag in album.data.tags %}{{ tag if "AlbumGroup/" in tag }}{% endfor %}{% endset %}
      {% set groupTitle = albumGroup | replace("AlbumGroup/", "") %}

      {% if currentGroup != albumGroup %}
        {% if prevAlbumOpen %}</li>{% endif %}
        {% if currentGroup != "" %}</ol></li>{% endif %}
        <li class="album-group">
          <h2 class="album-group__title">{{ groupTitle }}&ensp;</h2>
          <ol class="album-group__albums-list">
        {% set currentGroup = albumGroup %}
      {% else %}
        {% if prevAlbumOpen %},&ensp;</li>{% endif %}
      {% endif %}

      {% set previewSRC %}{{ remote.gallery.base }}/{{ remote.gallery.photos }}/{{ album.data.key }}/{{ album.data.thumbnail }}{% endset %}
      <li class="album-group__album">
        <a class="album-group__album__link" href="{{ album.data.permalink }}" data-preview="{{ previewSrc }}">{{ album.data.shortTitle if album.data.shortTitle else album.data.title }}</a>
        <div class="album-preview">
          {{  Picture(
              fileName = album.data.thumbnail,
              src = previewSRC,
              loading = "eager",
              isWNCDN = true
          ) }}
        </div>
      {% set prevAlbumOpen = true %}
    {% endif %}
  {% endeach %}
  {% if prevAlbumOpen %}</li>{% endif %}
  {% if currentGroup != "" %}</ol></li>{% endif %}
  {{ Footer(el="li") }}
</ol>
