{# 
  img(
    src = '' (path to image, ommitting extension
    ext = '' (png x) | other ext
    densities = [1, 2] (array of densities to include
    class = '' (classname to pass to img tag
    alt = ''
  )
#}

{%- macro img(
  src = '', 
  ext = 'png',
  densities = [1, 2],
  class = '',
  alt = '',
  suffix = ''
) -%}
  {% if densities[0] != 1 %}{% set minDensity = '@' + densities[0] + 'x' %}{% endif %}
  {#- '?format=webp' now rides the Cloudflare transform path instead of a query -#}
  {%- set webp = suffix == '?format=webp' -%}
  <img
    {% if class %}class="{{ class }}"{% endif %} src="
      {%- set u -%}{{ src }}{{ minDensity | replace(' ', '')}}.{{ ext }}{%- endset -%}
      {{- (u | cfImage) if webp else (u ~ suffix) -}}"
    srcset="
      {%- for i in densities -%}
        {%- set u -%}{{ src }}{{ minDensity if loop.first }}{{ '@' + i + 'x' if not loop.first }}.{{ ext }}{%- endset -%}
        {{- (u | cfImage) if webp else (u ~ suffix) }} {{ loop.index }}x{{ ', ' if not loop.last }}
      {%- endfor -%}"
    alt="{{ alt }}"
  />
{%- endmacro -%}
